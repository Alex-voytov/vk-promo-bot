[Unit]
Description=VK Promo Bot
After=network.target

[Service]
Type=simple
User=your_user
WorkingDirectory=/path/to/vk-promo-bot
Environment="PATH=/path/to/venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/path/to/venv/bin/python /path/to/vk-promo-bot/bot.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target